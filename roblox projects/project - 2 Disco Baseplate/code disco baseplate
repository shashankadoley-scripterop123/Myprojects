local baseplate = game.Workspace.Baseplate
local i = 1
while i <= 70 do
	baseplate.BrickColor = BrickColor.random()
	task.wait(1)
	i = i + 1
end


--[[This project is about making a disco baseplate.

For making an disco baseplate you can either use local or while loop.

Above is the code about WHILE loop.While loop is used when the user dosen't knows how many times the loop has to run

local i = 1 , is the starting value

local i <= 70 is the end value

i = i + 1, is the increment/increasing value

baseplate.BrickColor = BrickColor.random(), changes the colors randomly

task.wait(1), makes the colors wait 1 second before changing into another, without this we wont even see that the colors are changing 
because it is too fast.

Thats all! Thank you!

--]]
